{
  "schema_version": 1,
  "model_type": "dual_view_classifier",
  "onnx": {
    "file": "pill_cls.onnx",
    "input_mode": "auto",
    "input_names": [],
    "output_name": ""
  },
  "preprocess": {
    "img_size": 448,
    "color_space": "RGB",
    "normalize": {
      "mean": [
        0.485,
        0.456,
        0.406
      ],
      "std": [
        0.229,
        0.224,
        0.225
      ]
    },
    "crop_rotate": {
      "enabled": true
    }
  },
  "decision": {
    "min_conf_ok": 85.0,
    "min_margin_ok": 12.0,
    "ocr_min_quality": 0.75,
    "ocr_min_conf": 0.85,
    "verifier_trigger_margin": 15.0
  }
}